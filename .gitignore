# ====================================================================
# 🐍 PYTHON CORE
# ====================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.env
.venv
pip-log.txt
pip-delete-this-directory.txt

# ====================================================================
# 🧪 TESTING & REPORTS (COBOL PROTOCOL L0-L8)
# ====================================================================
# Abaikan file summary yang dihasilkan setiap kali eksekusi
*_SUMMARY.md
*_SUMMARY_INDONESIAN.md
*_DASHBOARD.txt
*_PROGRESS_*.md

# Abaikan detail logs dan hasil mentah JSON
*.log
TEST_RESULTS_*.json
LAYER_ANALYSIS_*.json
TEST_RUN_*.log

# Pytest & Coverage
.pytest_cache/
.coverage
htmlcov/
nosetests.xml
coverage.xml

# ====================================================================
# 📁 DATA & STORAGE
# ====================================================================
# Abaikan data input/output besar, kecuali folder template
data/*
!data/templates/
*.bin
*.dat
*.csv
# Pengecualian jika ada file config penting dalam folder data
!data/*.yaml

# ====================================================================
# 🖥️ IDE & SYSTEM SPECIFIC
# ====================================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
*.code-workspace

# PyCharm / JetBrains
.idea/

# System Files
.DS_Store
Thumbs.db
desktop.ini

# ====================================================================
# 📦 BUILD & DIST
# ====================================================================
build/
dist/
*.egg-info/
